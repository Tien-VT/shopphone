generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model addresses {
  id             BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  user_id        BigInt   @db.UnsignedBigInt
  recipient_name String   @db.VarChar(150)
  phone          String   @db.VarChar(20)
  address_line   String   @db.VarChar(255)
  ward           String?  @db.VarChar(120)
  district       String?  @db.VarChar(120)
  province       String?  @db.VarChar(120)
  is_default     Boolean  @default(false)
  created_at     DateTime @default(now()) @db.Timestamp(0)
  updated_at     DateTime @default(now()) @db.Timestamp(0)
  users          users    @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_addresses_user")
  orders         orders[]

  @@index([user_id], map: "idx_addresses_user_id")
}

model cart_items {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  cart_id    BigInt   @db.UnsignedBigInt
  product_id BigInt   @db.UnsignedBigInt
  quantity   Int      @default(1)
  unit_price Decimal  @default(0.00) @db.Decimal(14, 2)
  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @default(now()) @db.Timestamp(0)
  carts      carts    @relation(fields: [cart_id], references: [id], onDelete: Cascade, map: "fk_cart_items_cart")
  products   products @relation(fields: [product_id], references: [id], map: "fk_cart_items_product")

  @@unique([cart_id, product_id], map: "uq_cart_items_cart_product")
  @@index([product_id], map: "fk_cart_items_product")
}

model carts {
  id         BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
  user_id    BigInt       @unique(map: "uq_carts_user_id") @db.UnsignedBigInt
  created_at DateTime     @default(now()) @db.Timestamp(0)
  updated_at DateTime     @default(now()) @db.Timestamp(0)
  cart_items cart_items[]
  users      users        @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_carts_user")
}

model categories {
  id               BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
  name             String       @db.VarChar(150)
  slug             String       @unique(map: "uq_categories_slug") @db.VarChar(180)
  icon             String?      @db.VarChar(120)
  parent_id        BigInt?      @db.UnsignedBigInt
  is_active        Boolean      @default(true)
  sort_order       Int          @default(0)
  created_at       DateTime     @default(now()) @db.Timestamp(0)
  updated_at       DateTime     @default(now()) @db.Timestamp(0)
  categories       categories?  @relation("categoriesTocategories", fields: [parent_id], references: [id], map: "fk_categories_parent")
  other_categories categories[] @relation("categoriesTocategories")
  products         products[]

  @@index([parent_id], map: "idx_categories_parent_id")
}

model favorites {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  user_id    BigInt   @db.UnsignedBigInt
  product_id BigInt   @db.UnsignedBigInt
  created_at DateTime @default(now()) @db.Timestamp(0)
  products   products @relation(fields: [product_id], references: [id], onDelete: Cascade, map: "fk_favorites_product")
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_favorites_user")

  @@unique([user_id, product_id], map: "uq_favorites_user_product")
  @@index([product_id], map: "fk_favorites_product")
}

model flash_sales {
  id            BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  title         String             @db.VarChar(255)
  slug          String             @unique(map: "uq_flash_sales_slug") @db.VarChar(255)
  description   String?            @db.VarChar(500)
  products_json String?            @db.Text
  start_at      DateTime           @db.DateTime(0)
  end_at        DateTime           @db.DateTime(0)
  status        flash_sales_status @default(scheduled)
  created_at    DateTime           @default(now()) @db.Timestamp(0)
  updated_at    DateTime           @default(now()) @db.Timestamp(0)

  @@index([status], map: "idx_flash_sales_status")
}

model news_articles {
  id             BigInt               @id @default(autoincrement()) @db.UnsignedBigInt
  title          String               @db.VarChar(255)
  slug           String               @unique(map: "uq_news_articles_slug") @db.VarChar(255)
  excerpt        String?              @db.VarChar(500)
  content        String?              @db.Text
  thumbnail_url  String?              @db.VarChar(500)
  author_user_id BigInt?              @db.UnsignedBigInt
  status         news_articles_status @default(draft)
  published_at   DateTime?            @db.DateTime(0)
  created_at     DateTime             @default(now()) @db.Timestamp(0)
  updated_at     DateTime             @default(now()) @db.Timestamp(0)
  users          users?               @relation(fields: [author_user_id], references: [id], map: "fk_news_articles_author")

  @@index([author_user_id], map: "idx_news_articles_author_user_id")
}

model order_items {
  id           BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  order_id     BigInt   @db.UnsignedBigInt
  product_id   BigInt   @db.UnsignedBigInt
  product_name String   @db.VarChar(255)
  unit_price   Decimal  @default(0.00) @db.Decimal(14, 2)
  quantity     Int      @default(1)
  total_price  Decimal  @default(0.00) @db.Decimal(14, 2)
  created_at   DateTime @default(now()) @db.Timestamp(0)
  orders       orders   @relation(fields: [order_id], references: [id], onDelete: Cascade, map: "fk_order_items_order")
  products     products @relation(fields: [product_id], references: [id], map: "fk_order_items_product")

  @@index([order_id], map: "idx_order_items_order_id")
  @@index([product_id], map: "idx_order_items_product_id")
}

model orders {
  id              BigInt                @id @default(autoincrement()) @db.UnsignedBigInt
  order_code      String                @unique(map: "uq_orders_order_code") @db.VarChar(50)
  user_id         BigInt                @db.UnsignedBigInt
  address_id      BigInt?               @db.UnsignedBigInt
  voucher_id      BigInt?               @db.UnsignedBigInt
  subtotal        Decimal               @default(0.00) @db.Decimal(14, 2)
  discount_amount Decimal               @default(0.00) @db.Decimal(14, 2)
  shipping_fee    Decimal               @default(0.00) @db.Decimal(14, 2)
  total_amount    Decimal               @default(0.00) @db.Decimal(14, 2)
  payment_method  orders_payment_method @default(cod)
  payment_status  orders_payment_status @default(unpaid)
  order_status    orders_order_status   @default(pending)
  note            String?               @db.VarChar(500)
  created_at      DateTime              @default(now()) @db.Timestamp(0)
  updated_at      DateTime              @default(now()) @db.Timestamp(0)
  order_items     order_items[]
  addresses       addresses?            @relation(fields: [address_id], references: [id], map: "fk_orders_address")
  users           users                 @relation(fields: [user_id], references: [id], map: "fk_orders_user")
  vouchers        vouchers?             @relation(fields: [voucher_id], references: [id], map: "fk_orders_voucher")

  @@index([address_id], map: "fk_orders_address")
  @@index([voucher_id], map: "fk_orders_voucher")
  @@index([order_status], map: "idx_orders_status")
  @@index([user_id], map: "idx_orders_user_id")
}

model product_images {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  product_id BigInt   @db.UnsignedBigInt
  image_url  String   @db.VarChar(500)
  alt_text   String?  @db.VarChar(255)
  sort_order Int      @default(0)
  is_primary Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamp(0)
  products   products @relation(fields: [product_id], references: [id], onDelete: Cascade, map: "fk_product_images_product")

  @@index([product_id], map: "idx_product_images_product_id")
}

model products {
  id                BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  category_id       BigInt           @db.UnsignedBigInt
  name              String           @db.VarChar(255)
  slug              String           @unique(map: "uq_products_slug") @db.VarChar(255)
  sku               String           @unique(map: "uq_products_sku") @db.VarChar(100)
  short_description String?          @db.VarChar(500)
  description       String?          @db.Text
  specifications    String?          @db.Text
  color             String?          @db.VarChar(80)
  color_hex         String?          @db.VarChar(10)
  price             Decimal          @default(0.00) @db.Decimal(14, 2)
  old_price         Decimal?         @db.Decimal(14, 2)
  stock_quantity    Int              @default(0)
  is_featured       Boolean          @default(false)
  is_flash_sale     Boolean          @default(false)
  flash_sale_discount_percent Int?
  status            products_status  @default(active)
  created_at        DateTime         @default(now()) @db.Timestamp(0)
  updated_at        DateTime         @default(now()) @db.Timestamp(0)
  cart_items        cart_items[]
  favorites         favorites[]
  order_items       order_items[]
  product_images    product_images[]
  product_variants  product_variants[]
  product_reviews   product_reviews[]
  categories        categories       @relation(fields: [category_id], references: [id], map: "fk_products_category")

  @@index([category_id], map: "idx_products_category_id")
  @@index([status], map: "idx_products_status")
}

model product_variants {
  id             BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  product_id     BigInt   @db.UnsignedBigInt
  name           String   @db.VarChar(150)
  sku            String?  @db.VarChar(100)
  price          Decimal  @default(0.00) @db.Decimal(14, 2)
  old_price      Decimal? @db.Decimal(14, 2)
  stock_quantity Int      @default(0)
  color          String?  @db.VarChar(80)
  color_hex      String?  @db.VarChar(10)
  image_url      String?  @db.VarChar(500)
  sort_order     Int      @default(0)
  is_default     Boolean  @default(false)
  created_at     DateTime @default(now()) @db.Timestamp(0)
  updated_at     DateTime @default(now()) @db.Timestamp(0)
  products       products @relation(fields: [product_id], references: [id], onDelete: Cascade, map: "fk_variants_product")

  @@index([product_id], map: "idx_variants_product_id")
}

model users {
  id            BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  full_name     String             @db.VarChar(150)
  email         String             @unique(map: "uq_users_email")
  password_hash String             @db.VarChar(255)
  phone         String?            @unique(map: "uq_users_phone") @db.VarChar(20)
  role          users_role         @default(customer)
  status        users_status       @default(active)
  loyalty_tier  users_loyalty_tier @default(bronze)
  avatar_url    String?            @db.VarChar(500)
  created_at    DateTime           @default(now()) @db.Timestamp(0)
  updated_at    DateTime           @default(now()) @db.Timestamp(0)
  addresses     addresses[]
  carts         carts?
  favorites     favorites[]
  news_articles news_articles[]
  orders        orders[]
  product_reviews product_reviews[]
  review_replies  review_replies[]
  review_likes    review_likes[]
}

model vouchers {
  id                  BigInt                 @id @default(autoincrement()) @db.UnsignedBigInt
  code                String                 @unique(map: "uq_vouchers_code") @db.VarChar(50)
  name                String                 @db.VarChar(150)
  description         String?                @db.VarChar(500)
  discount_type       vouchers_discount_type
  discount_value      Decimal                @default(0.00) @db.Decimal(14, 2)
  minimum_order_value Decimal                @default(0.00) @db.Decimal(14, 2)
  max_discount_value  Decimal?               @db.Decimal(14, 2)
  start_at            DateTime?              @db.DateTime(0)
  end_at              DateTime?              @db.DateTime(0)
  usage_limit         Int?
  used_count          Int                    @default(0)
  status              vouchers_status        @default(active)
  created_at          DateTime               @default(now()) @db.Timestamp(0)
  updated_at          DateTime               @default(now()) @db.Timestamp(0)
  orders              orders[]
}

enum vouchers_discount_type {
  percent
  fixed
}

enum users_role {
  customer
  admin
}

enum flash_sales_status {
  scheduled
  active
  ended
  cancelled
}

enum users_status {
  active
  locked
  pending
}

enum news_articles_status {
  draft
  published
  archived
}

enum users_loyalty_tier {
  bronze
  silver
  gold
  diamond
}

enum orders_payment_method {
  cod
  bank_transfer
  momo
  card
}

enum orders_payment_status {
  unpaid
  paid
  refunded
}

enum orders_order_status {
  pending
  confirmed
  shipping
  completed
  cancelled
}

enum products_status {
  draft
  active
  hidden
}

enum vouchers_status {
  active
  inactive
  expired
}

model product_reviews {
  id             BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  product_id     BigInt           @db.UnsignedBigInt
  user_id        BigInt           @db.UnsignedBigInt
  rating         Int              @db.Int
  comment        String?          @db.Text
  image_url      String?          @db.VarChar(500)
  created_at     DateTime         @default(now()) @db.Timestamp(0)
  updated_at     DateTime         @default(now()) @db.Timestamp(0)
  
  products       products         @relation(fields: [product_id], references: [id], onDelete: Cascade, map: "fk_reviews_product")
  users          users            @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_reviews_user")
  review_replies review_replies[]
  review_likes   review_likes[]

  @@index([product_id])
  @@index([user_id])
}

model review_replies {
  id             BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  review_id      BigInt           @db.UnsignedBigInt
  user_id        BigInt           @db.UnsignedBigInt
  comment        String           @db.Text
  is_admin       Boolean          @default(false)
  created_at     DateTime         @default(now()) @db.Timestamp(0)
  
  product_reviews product_reviews @relation(fields: [review_id], references: [id], onDelete: Cascade, map: "fk_replies_review")
  users           users           @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_replies_user")

  @@index([review_id])
  @@index([user_id])
}

model review_likes {
  id             BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  review_id      BigInt           @db.UnsignedBigInt
  user_id        BigInt           @db.UnsignedBigInt
  
  product_reviews product_reviews @relation(fields: [review_id], references: [id], onDelete: Cascade, map: "fk_likes_review")
  users           users           @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_likes_user")

  @@unique([review_id, user_id], map: "uq_review_likes_user")
}
